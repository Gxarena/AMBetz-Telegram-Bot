# GCP Configuration (required for local development)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Telegram Configuration (for local dev only - use Secret Manager in production)
# With DEVELOPMENT_MODE=false, this must be set (or rely on Secret Manager). With DEVELOPMENT_MODE=true,
# TELEGRAM_BOT_TOKEN_TEST is tried first; TELEGRAM_BOT_TOKEN is a fallback for the same test bot.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_TOKEN_TEST=optional_second_token_for_dev_mode_true

# Stripe Configuration (for local dev only - use Secret Manager in production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Monthly (1 month) recurring — primary secret used by checkout and trials
STRIPE_PRICE_ID=price_your_stripe_price_id
# Optional: shorter plans on the same Stripe product (add matching secrets in GCP Secret Manager)
STRIPE_PRICE_ID_WEEK=price_your_1_week_price_id
STRIPE_PRICE_ID_2WEEK=price_your_2_week_price_id
# Important: use Test mode price IDs with sk_test_ keys, and Live mode price IDs with sk_live_ keys — mixed modes fail at checkout.
# If gcloud can read Secret Manager, GCP stripe-*-test secrets override .env unless you set:
# STRIPE_PREFER_DOTENV=true
# so STRIPE_SECRET_KEY / prices in .env win (useful for local live-key testing).

# Subscription price migration (scripts/stripe_migrate_subscription_price.py only)
# Use test keys and test price IDs first. Do not run --live against production until dry-run is reviewed.
OLD_PRICE_ID=price_old_monthly_to_migrate_from
NEW_PRICE_ID=price_new_monthly_to_migrate_to

# Optional: VIP group chat ids (negative numbers for supergroups) — for local scripts
# and optional env merge. Production often uses Secret Manager: vip-chat-id, vip-announcements-id.
VIP_CHAT_ID=your-telegram-group-chat-id
VIP_ANNOUNCEMENTS_ID=optional-second-vip-supergroup-id

# Local development settings
PORT=8080
# When true: DEBUG logs, dev-only bot commands, Secret Manager names get a "-test" suffix,
# and expired-sub checks run every minute. Stripe price env vars still work: if ...-test fails,
# the code falls back to STRIPE_PRICE_ID_WEEK (same names as below) without requiring _TEST.
DEVELOPMENT_MODE=false

# Note: In production, all sensitive values are stored in GCP Secret Manager
# This .env file is only for local development and testing
